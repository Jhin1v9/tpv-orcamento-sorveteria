                                <div>
                                    <p class="text-gray-600 text-sm">Pedido <span class="font-bold text-purple-600">#042</span></p>
                                    <p class="text-gray-400 text-xs">Milkshake - Menta</p>
                                </div>
                                <span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-bold">Em preparo</span>
                            </div>
