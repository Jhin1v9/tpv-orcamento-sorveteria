                    <div class="flex items-center gap-4">
                        <i class="fas fa-wifi text-green-500"></i>
                        <i class="fas fa-battery-full text-green-500"></i>
                    </div>
                </div>

                <!-- Toast -->
                <div id="kioskToast" class="toast">Mensagem</div>

                <!-- PÁGINAS -->
                <div class="kiosk-pages-wrapper">
                    <!-- HOME -->
