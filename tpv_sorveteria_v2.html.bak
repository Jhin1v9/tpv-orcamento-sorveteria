                                <i class="fas fa-ice-cream text-5xl text-white"></i>
                            </div>
                            <h2 class="text-3xl font-extrabold text-gray-800">Gelats Sabadell</h2>
                            <p class="text-gray-500">Sorveteria Artesanal desde 1985</p>
                        </div>

                        <!-- Carrossel de Promoções -->
                        <div class="mb-8">
                            <div class="bg-gradient-to-r from-pink-500 to-rose-400 rounded-3xl p-6 text-white shadow-xl relative overflow-hidden">
                                <div class="absolute -right-6 -top-6 w-32 h-32 bg-white/20 rounded-full"></div>
                                <div class="absolute right-10 bottom-0 w-20 h-20 bg-white/20 rounded-full"></div>
                                <p class="text-sm font-semibold uppercase tracking-wider opacity-90">Destaque do Dia</p>
                                <h3 class="text-2xl font-bold mt-1">Milkshake Duo</h3>
                                <p class="text-white/90 text-sm mt-1">2 milkshakes por €7.50</p>
                                <button onclick="pedidoRapidoDuo()" class="mt-4 px-5 py-2 bg-white text-rose-500 rounded-full font-bold text-sm shadow hover:scale-105 transition">Pedir Agora</button>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4 mb-6">
                            <button onclick="navegarPara('cardapio')" class="base-card bg-white rounded-2xl p-5 shadow text-left border border-gray-100">
                                <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-3 text-purple-600 text-xl"><i class="fas fa-utensils"></i></div>
                                <p class="font-bold text-gray-800">Novo Pedido</p>
                                <p class="text-xs text-gray-500">Monte seu sorvete</p>
