    <section class="py-20 bg-gray-900 text-white">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-6">Experimente o Kiosk em Tela Cheia</h2>
            <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">Simulação realista de um tablet de autoatendimento com navegação por toque, carrinho inteligente e pagamento integrado.</p>
            <button onclick="abrirSimulador()" class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full font-bold text-xl shadow-2xl hover:scale-105 transition pulse-soft">
                <i class="fas fa-tablet-alt"></i>
                Abrir Simulador de Tablet
            </button>
            <div class="mt-10 flex flex-wrap justify-center gap-6 text-sm text-gray-400">
                <span class="flex items-center gap-2"><i class="fas fa-wifi text-green-400"></i> Status Bar Simulada</span>
                <span class="flex items-center gap-2"><i class="fas fa-shopping-cart text-purple-400"></i> Carrinho em Tempo Real</span>
                <span class="flex items-center gap-2"><i class="fas fa-qrcode text-pink-400"></i> Pagamento Bizum/QR</span>
                <span class="flex items-center gap-2"><i class="fas fa-receipt text-yellow-400"></i> Fatura VeriFactu</span>
            </div>
        </div>
    </section>

    <!-- SIMULADOR FULLSCREEN OVERLAY -->
