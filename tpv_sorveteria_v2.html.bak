<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TPV Self-Service Sorveteria | Sabadell Nord</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { font-family: 'Poppins', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .gradient-warm { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
        .hover-scale { transition: transform 0.3s ease; }
        .hover-scale:hover { transform: scale(1.05); }
        .float { animation: float 3s ease-in-out infinite; }
        @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-20px); } }
        .ice-cream-float { animation: ice-cream-float 4s ease-in-out infinite; }
        @keyframes ice-cream-float { 0%, 100% { transform: rotate(-3deg) translateY(0); } 50% { transform: rotate(3deg) translateY(-15px); } }
        .demo-tablet { width: 100%; max-width: 400px; height: 700px; background: #000; border-radius: 40px; padding: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); margin: 0 auto; }
        .demo-screen { width: 100%; height: 100%; background: linear-gradient(180deg, #667eea 0%, #764ba2 100%); border-radius: 30px; overflow: hidden; position: relative; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* ===== SIMULADOR FULLSCREEN TABLET ===== */
        #simuladorTablet {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            z-index: 9999;
            background: #0f0f11;
            display: none;
            align-items: center;
            justify-content: center;
        }
        #simuladorTablet.ativo { display: flex; }

        .tablet-frame {
            width: 100vw;
            height: 100vh;
            background: #111;
            border-radius: 0;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        @media (min-width: 1024px) {
            .tablet-frame {
                width: min(95vw, 1400px);
                height: min(95vh, 950px);
                border-radius: 48px;
                border: 14px solid #1a1a1a;
            }
            .tablet-frame::before {
                content: '';
                position: absolute;
                top: 12px;
                left: 50%;
                transform: translateX(-50%);
                width: 120px;
                height: 24px;
                background: #0a0a0a;
                border-radius: 12px;
                z-index: 50;
            }
            .tablet-frame::after {
                content: '';
                position: absolute;
                top: 18px;
                left: 50%;
                transform: translateX(-50%);
                width: 14px;
                height: 14px;
                background: #222;
                border-radius: 50%;
                z-index: 51;
                box-shadow: inset 0 0 4px #000;
            }
        }

        .kiosk-screen {
            flex: 1;
            background: linear-gradient(180deg, #f8f9fc 0%, #eef2f7 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border-radius: inherit;
        }

        .status-bar {
            height: 44px;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            z-index: 40;
        }

        .bottom-nav {
            height: 80px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 40;
            padding-bottom: env(safe-area-inset-bottom, 0px);
        }

        .bottom-nav button {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: #9ca3af;
            font-size: 12px;
            font-weight: 600;
            transition: color 0.2s;
        }
        .bottom-nav button.ativo { color: #7c3aed; }
        .bottom-nav button i { font-size: 22px; }

        .kiosk-pages-wrapper {
            flex: 1;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .kiosk-page {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 24px;
            display: none;
            animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .kiosk-page.ativo {
            display: flex;
            flex-direction: column;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse-soft {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.03); }
        }
        .pulse-soft { animation: pulse-soft 2s infinite; }

        .toast {
            position: fixed;
            top: 60px;
            left: 50%;
            transform: translateX(-50%) translateY(-20px);
            background: #1f2937;
            color: #fff;
            padding: 12px 24px;
            border-radius: 999px;
            font-size: 14px;
            font-weight: 500;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            z-index: 100;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

        .sabor-card, .extra-card, .base-card {
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        .sabor-card:active, .extra-card:active, .base-card:active { transform: scale(0.96); }

        .close-kiosk {
            position: absolute;
            top: 56px;
            right: 24px;
            width: 40px;
            height: 40px;
            background: rgba(0,0,0,0.4);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 60;
            cursor: pointer;
            transition: background 0.2s;
        }
        .close-kiosk:hover { background: rgba(0,0,0,0.6); }

        @media (min-width: 1024px) {
            .close-kiosk { top: 28px; right: 28px; }
        }

        .pay-method {
            transition: all 0.2s;
        }
        .pay-method:hover {
            border-color: #7c3aed;
            background: #f5f3ff;
        }
        .pay-method.selected {
            border-color: #7c3aed;
            background: #ede9fe;
            box-shadow: 0 0 0 3px rgba(124,58,237,0.15);
        }

        .cart-item-anim { animation: popIn 0.3s ease; }
        @keyframes popIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
    </style>
</head>
<body class="bg-gray-50">

    <!-- HERO -->
    <section class="gradient-bg min-h-screen flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute top-20 left-20 w-32 h-32 bg-white rounded-full blur-3xl"></div>
            <div class="absolute bottom-20 right-20 w-48 h-48 bg-pink-300 rounded-full blur-3xl"></div>
            <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-yellow-300 rounded-full blur-3xl transform -translate-x-1/2 -translate-y-1/2"></div>
        </div>
        <div class="container mx-auto px-6 relative z-10 text-center">
            <div class="ice-cream-float inline-block mb-6">
                <i class="fas fa-ice-cream text-8xl text-white drop-shadow-2xl"></i>
            </div>
            <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 drop-shadow-lg">TPV Self-Service</h1>
            <p class="text-2xl text-white/90 mb-4 font-light">Sorveteria Sabadell Nord</p>
            <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">Sistema completo: Kiosk + Dashboard Cozinha + Admin Total</p>
            <div class="flex flex-wrap justify-center gap-4">
                <span class="px-6 py-3 bg-white/20 rounded-full text-white font-semibold backdrop-blur"><i class="fas fa-robot mr-2"></i>Automação</span>
                <span class="px-6 py-3 bg-white/20 rounded-full text-white font-semibold backdrop-blur"><i class="fas fa-chart-line mr-2"></i>Dashboard</span>
                <span class="px-6 py-3 bg-white/20 rounded-full text-white font-semibold backdrop-blur"><i class="fas fa-shield-alt mr-2"></i>VeriFactu</span>
            </div>
        </div>
    </section>

    <!-- ANÁLISE ELO WALLABY -->
    <section class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-800 mb-4">Elo Wallaby: O Que Vem Pronto</h2>
                <p class="text-xl text-gray-600">Análise técnica completa do hardware</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto mb-12">
                <div class="bg-green-50 border-2 border-green-200 rounded-3xl p-8">
                    <h3 class="text-2xl font-bold text-green-700 mb-6"><i class="fas fa-box-open mr-3"></i>Na Caixa (100% Funcional)</h3>
                    <div class="space-y-4">
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-check text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Display I-Series 22" Android</p><p class="text-sm text-gray-600">Qualcomm Snapdragon, 4GB RAM, 64GB, Android 12</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-check text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Suporte Wallaby Metálico</p><p class="text-sm text-gray-600">Balcão ou chão, anti-vandalismo, cabos organizados</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-check text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Impressora Epson Integrada</p><p class="text-sm text-gray-600">250mm/s, 80mm, auto-cutter, já instalada</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-check text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">EloView Core (MDM)</p><p class="text-sm text-gray-600">Kiosk mode, remote control, OTA - GRÁTIS 2 anos</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-check text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">SDK Elo Peripheral</p><p class="text-sm text-gray-600">API documentada para controlar todos os periféricos</p></div>
                        </div>
                    </div>
                    <div class="mt-6 bg-green-100 rounded-xl p-4">
                        <p class="text-green-800 font-semibold text-center"><i class="fas fa-clock mr-2"></i>Economia: ~40-50h de trabalho vs kiosk genérico</p>
                    </div>
                </div>

                <div class="bg-blue-50 border-2 border-blue-200 rounded-3xl p-8">
                    <h3 class="text-2xl font-bold text-blue-700 mb-6"><i class="fas fa-code mr-3"></i>O Que Programamos</h3>
                    <div class="space-y-4">
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-mobile-alt text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">App Flutter (Cliente)</p><p class="text-sm text-gray-600">~80h - Telas de pedido, cardápio, pagamento</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-purple-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-utensils text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Dashboard Cozinha</p><p class="text-sm text-gray-600">~20h - Fila de pedidos em tempo real</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-indigo-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-cog text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Dashboard Admin</p><p class="text-sm text-gray-600">~40h - Vendas, estatísticas, faturas, controle total</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-orange-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-cloud text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">Backend Supabase</p><p class="text-sm text-gray-600">~30h - API REST, PostgreSQL, auth, realtime</p></div>
                        </div>
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-red-500 rounded-full flex items-center justify-center mr-3 mt-1"><i class="fas fa-file-invoice text-white text-sm"></i></div>
                            <div><p class="font-semibold text-gray-800">VeriFactu 2026</p><p class="text-sm text-gray-600">~40h - Integração API AEAT, QR code fiscal</p></div>
                        </div>
                    </div>
                    <div class="mt-6 bg-blue-100 rounded-xl p-4">
                        <p class="text-blue-800 font-semibold text-center"><i class="fas fa-clock mr-2"></i>Total: ~210h de desenvolvimento profissional incluído</p>
                    </div>
                </div>
            </div>

            <div class="max-w-4xl mx-auto bg-gray-100 rounded-2xl p-8">
                <h4 class="text-xl font-bold text-center text-gray-800 mb-6">Economia de Tempo: Elo vs Genérico</h4>
                <div class="space-y-4">
                    <div class="flex items-center">
                        <span class="w-48 text-gray-700 font-semibold">Integração impressora</span>
                        <div class="flex-1 bg-gray-200 rounded-full h-6 mr-4 relative overflow-hidden">
                            <div class="absolute left-0 top-0 h-full bg-green-500 rounded-full" style="width: 20%"></div>
                            <div class="absolute left-0 top-0 h-full bg-red-400 rounded-full" style="width: 100%; opacity: 0.3"></div>
                        </div>
                        <span class="text-sm text-gray-600 w-24">4h vs 20h</span>
                    </div>
                    <div class="flex items-center">
                        <span class="w-48 text-gray-700 font-semibold">Configuração MDM</span>
                        <div class="flex-1 bg-gray-200 rounded-full h-6 mr-4 relative overflow-hidden">
                            <div class="absolute left-0 top-0 h-full bg-green-500 rounded-full" style="width: 13%"></div>
                            <div class="absolute left-0 top-0 h-full bg-red-400 rounded-full" style="width: 100%; opacity: 0.3"></div>
                        </div>
                        <span class="text-sm text-gray-600 w-24">2h vs 15h</span>
                    </div>
                    <div class="flex items-center">
                        <span class="w-48 text-gray-700 font-semibold">Suporte mensal</span>
                        <div class="flex-1 bg-gray-200 rounded-full h-6 mr-4 relative overflow-hidden">
                            <div class="absolute left-0 top-0 h-full bg-green-500 rounded-full" style="width: 20%"></div>
                            <div class="absolute left-0 top-0 h-full bg-red-400 rounded-full" style="width: 100%; opacity: 0.3"></div>
                        </div>
                        <span class="text-sm text-gray-600 w-24">2h vs 10h</span>
                    </div>
                </div>
                <p class="text-center text-gray-600 mt-4 text-sm"><i class="fas fa-info-circle mr-2"></i>Elo Wallaby poupou 120h no 1º ano = €6.000 de economia (à €50/h)</p>
            </div>
        </div>
    </section>

    <!-- DEMO INTERATIVA ORIGINAL -->
    <section class="py-20 gradient-warm">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-800 mb-4">Demo Interativa do Sistema</h2>
                <p class="text-xl text-gray-700">Teste o app exatamente como será na sorveteria</p>
            </div>

            <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto items-start">
                <!-- TABLET CLIENTE -->
                <div class="demo-tablet">
                    <div class="demo-screen" id="demoScreen">
                        <!-- TELA INICIAL -->
                        <div id="telaInicial" class="h-full flex flex-col p-6 fade-in">
                            <div class="text-center mb-8">
                                <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-ice-cream text-4xl text-white"></i>
                                </div>
                                <h2 class="text-2xl font-bold text-white">Gelats Sabadell</h2>
                                <p class="text-white/80">Toque para começar</p>
                            </div>
                            <div class="flex gap-4 mb-6">
                                <button onclick="mudarIdioma('cat')" class="flex-1 py-3 bg-white/20 rounded-xl text-white font-semibold hover:bg-white/30 transition">Català</button>
                                <button onclick="mudarIdioma('esp')" class="flex-1 py-3 bg-white/20 rounded-xl text-white font-semibold hover:bg-white/30 transition">Español</button>
                            </div>
                            <button onclick="mostrarCardapio()" class="w-full py-4 bg-white text-purple-600 rounded-2xl font-bold text-lg shadow-lg hover:scale-105 transition">
                                <i class="fas fa-play mr-2"></i>Iniciar Pedido
                            </button>
                            <div class="mt-auto text-center">
                                <p class="text-white/60 text-sm">Sorveteria Artesanal desde 1985</p>
                            </div>
                        </div>

                        <!-- TELA CARDÁPIO -->
                        <div id="telaCardapio" class="h-full flex flex-col p-6 hidden">
                            <div class="flex items-center mb-4">
                                <button onclick="voltarInicial()" class="text-white mr-4"><i class="fas fa-arrow-left text-xl"></i></button>
                                <h2 class="text-xl font-bold text-white">Escolha a Base</h2>
                            </div>
                            <div class="grid grid-cols-2 gap-4 overflow-y-auto hide-scrollbar flex-1">
                                <button onclick="selecionarBase('copo')" class="bg-white/20 rounded-2xl p-4 text-center hover:bg-white/30 transition">
                                    <i class="fas fa-glass-whiskey text-4xl text-white mb-2"></i>
                                    <p class="text-white font-semibold">Copo</p><p class="text-white/70 text-sm">€3.50</p>
                                </button>
                                <button onclick="selecionarBase('cone')" class="bg-white/20 rounded-2xl p-4 text-center hover:bg-white/30 transition">
                                    <i class="fas fa-caret-up text-4xl text-white mb-2"></i>
                                    <p class="text-white font-semibold">Cone</p><p class="text-white/70 text-sm">€3.00</p>
                                </button>
                                <button onclick="selecionarBase('pote')" class="bg-white/20 rounded-2xl p-4 text-center hover:bg-white/30 transition">
                                    <i class="fas fa-bowl-food text-4xl text-white mb-2"></i>
                                    <p class="text-white font-semibold">Pote 500ml</p><p class="text-white/70 text-sm">€6.00</p>
                                </button>
                                <button onclick="selecionarBase('milkshake')" class="bg-white/20 rounded-2xl p-4 text-center hover:bg-white/30 transition">
                                    <i class="fas fa-glass-water text-4xl text-white mb-2"></i>
                                    <p class="text-white font-semibold">Milkshake</p><p class="text-white/70 text-sm">€4.50</p>
                                </button>
                            </div>
                        </div>

                        <!-- TELA SABORES -->
                        <div id="telaSabores" class="h-full flex flex-col p-6 hidden">
                            <div class="flex items-center mb-4">
                                <button onclick="voltarCardapio()" class="text-white mr-4"><i class="fas fa-arrow-left text-xl"></i></button>
                                <h2 class="text-xl font-bold text-white">Escolha até 3 Sabores</h2>
                            </div>
                            <div class="text-center mb-4">
                                <span id="contadorSabores" class="bg-white text-purple-600 px-4 py-1 rounded-full font-bold">0/3</span>
                            </div>
                            <div class="grid grid-cols-2 gap-3 overflow-y-auto hide-scrollbar flex-1">
                                <button onclick="toggleSabor('vainilla')" id="sabor-vainilla" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-yellow-200 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🍦</span></div>
                                    <p class="text-white font-semibold text-sm">Baunilha</p>
                                </button>
                                <button onclick="toggleSabor('chocolate')" id="sabor-chocolate" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-amber-800 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🍫</span></div>
                                    <p class="text-white font-semibold text-sm">Chocolate</p>
                                </button>
                                <button onclick="toggleSabor('morango')" id="sabor-morango" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-pink-400 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🍓</span></div>
                                    <p class="text-white font-semibold text-sm">Morango</p>
                                </button>
                                <button onclick="toggleSabor('menta')" id="sabor-menta" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-green-300 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🌿</span></div>
                                    <p class="text-white font-semibold text-sm">Menta</p>
                                </button>
                                <button onclick="toggleSabor('cookie')" id="sabor-cookie" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-amber-600 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🍪</span></div>
                                    <p class="text-white font-semibold text-sm">Cookies</p>
                                </button>
                                <button onclick="toggleSabor('manga')" id="sabor-manga" class="bg-white/20 rounded-xl p-3 text-center hover:bg-white/30 transition sabor-btn">
                                    <div class="w-12 h-12 bg-yellow-400 rounded-full mx-auto mb-2 flex items-center justify-center"><span class="text-2xl">🥭</span></div>
                                    <p class="text-white font-semibold text-sm">Manga</p>
                                </button>
                            </div>
                            <button onclick="mostrarCarrinho()" id="btnContinuar" class="w-full py-3 bg-white text-purple-600 rounded-xl font-bold mt-4 opacity-50" disabled>
                                Continuar <i class="fas fa-arrow-right ml-2"></i>
                            </button>
                        </div>

                        <!-- TELA CARRINHO -->
                        <div id="telaCarrinho" class="h-full flex flex-col p-6 hidden">
                            <div class="flex items-center mb-4">
                                <button onclick="voltarSabores()" class="text-white mr-4"><i class="fas fa-arrow-left text-xl"></i></button>
                                <h2 class="text-xl font-bold text-white">Seu Pedido</h2>
                            </div>
                            <div class="bg-white/20 rounded-2xl p-4 mb-4 flex-1 overflow-y-auto hide-scrollbar">
                                <div id="resumoPedido" class="space-y-3"></div>
                                <div class="border-t border-white/30 pt-3 mt-3">
                                    <div class="flex justify-between text-white mb-2"><span>Subtotal</span><span id="subtotal">€0.00</span></div>
                                    <div class="flex justify-between text-white font-bold text-lg"><span>Total</span><span id="total">€0.00</span></div>
                                </div>
                            </div>
                            <button onclick="mostrarPagamento()" class="w-full py-4 bg-green-400 text-white rounded-2xl font-bold text-lg shadow-lg hover:scale-105 transition">
                                <i class="fas fa-credit-card mr-2"></i>Pagar €<span id="totalBtn">0.00</span>
                            </button>
                        </div>

                        <!-- TELA PAGAMENTO -->
                        <div id="telaPagamento" class="h-full flex flex-col p-6 hidden">
                            <h2 class="text-xl font-bold text-white text-center mb-6">Forma de Pagamento</h2>
                            <div class="space-y-4 flex-1">
                                <button onclick="processarPagamento('cartao')" class="w-full py-4 bg-white/20 rounded-2xl text-white font-semibold hover:bg-white/30 transition flex items-center justify-center">
                                    <i class="fas fa-credit-card text-2xl mr-4"></i>
                                    <div class="text-left"><p class="font-bold">Cartão</p><p class="text-sm text-white/70">Débito/Crédito</p></div>
                                </button>
                                <button onclick="processarPagamento('dinheiro')" class="w-full py-4 bg-white/20 rounded-2xl text-white font-semibold hover:bg-white/30 transition flex items-center justify-center">
                                    <i class="fas fa-money-bill-wave text-2xl mr-4"></i>
                                    <div class="text-left"><p class="font-bold">Dinheiro</p><p class="text-sm text-white/70">Pague no caixa</p></div>
                                </button>
                                <button onclick="processarPagamento('qr')" class="w-full py-4 bg-white/20 rounded-2xl text-white font-semibold hover:bg-white/30 transition flex items-center justify-center">
                                    <i class="fas fa-qrcode text-2xl mr-4"></i>
                                    <div class="text-left"><p class="font-bold">Bizum/QR</p><p class="text-sm text-white/70">Pagamento instantâneo</p></div>
                                </button>
                            </div>
                        </div>

                        <!-- TELA CONFIRMAÇÃO -->
                        <div id="telaConfirmacao" class="h-full flex flex-col p-6 hidden">
                            <div class="flex-1 flex flex-col items-center justify-center text-center">
                                <div class="w-24 h-24 bg-green-400 rounded-full flex items-center justify-center mb-6 animate-bounce">
                                    <i class="fas fa-check text-4xl text-white"></i>
                                </div>
                                <h2 class="text-2xl font-bold text-white mb-2">Pedido Confirmado!</h2>
                                <p class="text-white/80 mb-6">Número do pedido</p>
                                <div class="bg-white rounded-2xl px-8 py-4 mb-6">
                                    <span class="text-4xl font-bold text-purple-600">#042</span>
                                </div>
                                <div class="bg-white/20 rounded-xl p-4 mb-6 w-full">
                                    <p class="text-white text-sm mb-2">QR Code VeriFactu</p>
                                    <div class="w-32 h-32 bg-white mx-auto rounded-lg flex items-center justify-center">
                                        <i class="fas fa-qrcode text-6xl text-gray-800"></i>
                                    </div>
                                </div>
                                <p class="text-white/70 text-sm">Tempo estimado: 3 minutos</p>
                            </div>
                            <button onclick="voltarInicial()" class="w-full py-3 bg-white/20 rounded-xl text-white font-semibold">
                                <i class="fas fa-plus mr-2"></i>Novo Pedido
                            </button>
                        </div>
                    </div>
                </div>

