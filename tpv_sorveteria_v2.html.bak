                    <div class="text-center">
                        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3"><i class="fas fa-mobile-alt text-2xl text-blue-600"></i></div>
                        <p class="font-bold text-gray-800">App Cliente</p>
                        <p class="text-sm text-gray-600">~80h desenvolvimento</p>
                    </div>
                    <div class="text-center">
                        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3"><i class="fas fa-utensils text-2xl text-green-600"></i></div>
                        <p class="font-bold text-gray-800">Dashboard Cozinha</p>
                        <p class="text-sm text-gray-600">~20h desenvolvimento</p>
                    </div>
                    <div class="text-center">
                        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3"><i class="fas fa-chart-pie text-2xl text-purple-600"></i></div>
                        <p class="font-bold text-gray-800">Dashboard Admin</p>
                        <p class="text-sm text-gray-600">~40h desenvolvimento</p>
                    </div>
                </div>
                <div class="mt-6 text-center">
                    <p class="text-gray-600">+ Backend Supabase (~30h) + VeriFactu (~40h)</p>
                    <p class="text-xl font-bold text-gray-800 mt-2">Total: ~210h de desenvolvimento profissional incluído</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 gradient-bg">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Pronto para Revolucionar sua Sorveteria?</h2>
            <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">Sistema completo: Kiosk + Dashboard Cozinha + Admin Total. Seja nosso primeiro cliente!</p>
            <div class="flex flex-wrap justify-center gap-6 mb-12">
                <div class="bg-white/20 backdrop-blur rounded-2xl p-6 text-white">
                    <i class="fas fa-phone text-3xl mb-3"></i>
                    <p class="font-semibold">Ligar Agora</p>
                    <p class="text-2xl font-bold">[Telefone]</p>
                </div>
                <div class="bg-white/20 backdrop-blur rounded-2xl p-6 text-white">
                    <i class="fas fa-envelope text-3xl mb-3"></i>
                    <p class="font-semibold">Email</p>
                    <p class="text-lg font-bold">abner@exemplo.com</p>
                </div>
                <div class="bg-white/20 backdrop-blur rounded-2xl p-6 text-white">
                    <i class="fas fa-map-marker-alt text-3xl mb-3"></i>
                    <p class="font-semibold">Local</p>
                    <p class="text-lg font-bold">Sabadell, Catalunha</p>
                </div>
            </div>
            <div class="bg-white rounded-3xl p-8 max-w-3xl mx-auto shadow-2xl">
                <h3 class="text-2xl font-bold text-gray-800 mb-6">Escolha seu Plano</h3>
                <div class="grid md:grid-cols-2 gap-4 text-left mb-6">
                    <div class="bg-gray-50 rounded-xl p-4 border-2 border-gray-200 cursor-pointer hover:border-blue-500 transition">
                        <p class="font-bold text-gray-800">Econômica</p>
                        <p class="text-2xl font-bold text-gray-600">€638 + €150/mês</p>
                        <p class="text-sm text-gray-500">Kiosk básico + sistema essencial</p>
                    </div>
                    <div class="bg-purple-50 rounded-xl p-4 border-2 border-purple-500 cursor-pointer">
                        <p class="font-bold text-purple-800">Profissional</p>
                        <p class="text-2xl font-bold text-purple-600">€1.508 + €250/mês</p>
                        <p class="text-sm text-purple-600">Elo Wallaby + sistema completo</p>
                    </div>
                </div>
                <p class="text-gray-500 text-sm"><i class="fas fa-info-circle mr-2"></i>Manutenção inclui: suporte remoto, updates, backup, alterações cardápio</p>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-white py-12">
        <div class="container mx-auto px-6 text-center">
            <div class="flex justify-center gap-6 mb-6">
                <i class="fas fa-ice-cream text-4xl text-pink-400"></i>
                <i class="fas fa-laptop-code text-4xl text-blue-400"></i>
                <i class="fas fa-chart-line text-4xl text-green-400"></i>
                <i class="fas fa-mobile-alt text-4xl text-purple-400"></i>
            </div>
            <p class="text-xl font-bold mb-2">Abner • Enoque • Elias</p>
            <p class="text-gray-400 mb-6">Programadores & TPV Specialists | Sabadell 2026</p>
            <div class="flex justify-center gap-4 text-sm text-gray-500">
                <span><i class="fas fa-check mr-1"></i>App Cliente</span>
                <span><i class="fas fa-check mr-1"></i>Dashboard Cozinha</span>
                <span><i class="fas fa-check mr-1"></i>Admin Completo</span>
                <span><i class="fas fa-check mr-1"></i>VeriFactu 2026</span>
            </div>
        </div>
    </footer>

    <!-- JAVASCRIPT -->
    <script>
        // ===== DEMO ORIGINAL =====
        let pedido = { base: null, basePreco: 0, sabores: [], extras: [] };
        const precos = { copo: 3.50, cone: 3.00, pote: 6.00, milkshake: 4.50 };
        const nomes = { copo: 'Copo', cone: 'Cone', pote: 'Pote 500ml', milkshake: 'Milkshake', vainilla: 'Baunilha', chocolate: 'Chocolate', morango: 'Morango', menta: 'Menta', cookie: 'Cookies', manga: 'Manga' };

        function esconderTodas() {
            document.getElementById('telaInicial').classList.add('hidden');
            document.getElementById('telaCardapio').classList.add('hidden');
            document.getElementById('telaSabores').classList.add('hidden');
            document.getElementById('telaCarrinho').classList.add('hidden');
            document.getElementById('telaPagamento').classList.add('hidden');
            document.getElementById('telaConfirmacao').classList.add('hidden');
        }

        function mostrarTela(id) {
            esconderTodas();
            document.getElementById(id).classList.remove('hidden');
            document.getElementById(id).classList.add('fade-in');
        }

        function mudarIdioma(lang) { alert('Idioma alterado para: ' + (lang === 'cat' ? 'Català' : 'Español')); }
        function mostrarCardapio() { mostrarTela('telaCardapio'); }
        function voltarInicial() { pedido = { base: null, basePreco: 0, sabores: [], extras: [] }; atualizarContador(); mostrarTela('telaInicial'); }
        function voltarCardapio() { mostrarTela('telaCardapio'); }
        function voltarSabores() { mostrarTela('telaSabores'); }

        function selecionarBase(base) {
            pedido.base = base;
            pedido.basePreco = precos[base];
            mostrarTela('telaSabores');
        }

        function toggleSabor(sabor) {
            const index = pedido.sabores.indexOf(sabor);
            const btn = document.getElementById('sabor-' + sabor);

            if (index > -1) {
                pedido.sabores.splice(index, 1);
                btn.classList.remove('bg-white', 'text-purple-600');
                btn.classList.add('bg-white/20');
            } else if (pedido.sabores.length < 3) {
                pedido.sabores.push(sabor);
                btn.classList.remove('bg-white/20');
                btn.classList.add('bg-white', 'text-purple-600');
            }

            atualizarContador();
        }

        function atualizarContador() {
            document.getElementById('contadorSabores').textContent = pedido.sabores.length + '/3';
            const btn = document.getElementById('btnContinuar');
            if (pedido.sabores.length > 0) {
                btn.disabled = false;
                btn.classList.remove('opacity-50');
            } else {
                btn.disabled = true;
                btn.classList.add('opacity-50');
            }
        }

        function mostrarCarrinho() {
            const resumo = document.getElementById('resumoPedido');
            let html = '<div class="flex justify-between text-white mb-2"><span>' + nomes[pedido.base] + '</span><span>€' + pedido.basePreco.toFixed(2) + '</span></div>';

            pedido.sabores.forEach(s => {
                html += '<div class="flex justify-between text-white/80 text-sm"><span>• ' + nomes[s] + '</span><span>incluído</span></div>';
            });

            resumo.innerHTML = html;
            document.getElementById('subtotal').textContent = '€' + pedido.basePreco.toFixed(2);
            document.getElementById('total').textContent = '€' + pedido.basePreco.toFixed(2);
            document.getElementById('totalBtn').textContent = pedido.basePreco.toFixed(2);
            mostrarTela('telaCarrinho');
        }

        function mostrarPagamento() { mostrarTela('telaPagamento'); }

        function processarPagamento(metodo) {
            setTimeout(() => { mostrarTela('telaConfirmacao'); }, 500);
        }

        // ===== SIMULADOR KIOSK FULLSCREEN =====
        const kioskPrecos = { copo: 3.50, cone: 3.00, pote: 6.00, milkshake: 4.50 };
        const kioskNomes = {
            copo: 'Copo', cone: 'Cone', pote: 'Pote 500ml', milkshake: 'Milkshake',
            vainilla: 'Baunilha', chocolate: 'Chocolate', morango: 'Morango', menta: 'Menta',
            cookie: 'Cookies', manga: 'Manga', coco: 'Coco', cafe: 'Café', limao: 'Limão',
            granola: 'Granola', calda_chocolate: 'Calda Chocolate', chantilly: 'Chantilly',
            amendoim: 'Amendoim', cereja: 'Cereja', oreo: 'Oreo'
        };
        const kioskExtrasPrecos = {
            granola: 0.50, calda_chocolate: 0.50, chantilly: 0.50,
            amendoim: 0.50, cereja: 0.50, oreo: 0.50
        };
        let kioskPedido = { base: null, basePreco: 0, sabores: [], extras: [] };
        let kioskPagamentoSelecionado = null;

        function abrirSimulador() {
            document.getElementById('simuladorTablet').classList.add('ativo');
            document.body.style.overflow = 'hidden';
            atualizarRelogio();
            navegarPara('home');
            vibrarCurto();
        }

        function fecharSimulador() {
            document.getElementById('simuladorTablet').classList.remove('ativo');
            document.body.style.overflow = '';
        }

        function navegarPara(pagina) {
            document.querySelectorAll('.kiosk-page').forEach(el => el.classList.remove('ativo'));
            document.getElementById('page' + capitalize(pagina)).classList.add('ativo');

            document.querySelectorAll('.bottom-nav button').forEach(el => el.classList.remove('ativo'));
            const navBtn = document.getElementById('nav' + capitalize(pagina));
            if (navBtn) navBtn.classList.add('ativo');

            if (pagina === 'carrinho') atualizarCarrinhoKiosk();
            vibrarCurto();
        }

        function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

        function vibrarCurto() {
            if (navigator.vibrate) navigator.vibrate(15);
        }

        function mostrarToast(msg) {
            const t = document.getElementById('kioskToast');
            t.textContent = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 2500);
        }

        function selecionarBaseKiosk(base) {
            kioskPedido.base = base;
            kioskPedido.basePreco = kioskPrecos[base];
            kioskPedido.sabores = [];
            kioskPedido.extras = [];
            // reset visual sabores
            document.querySelectorAll('[id^="kiosk-sabor-"]').forEach(btn => {
                btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50');
                btn.classList.add('bg-white');
            });
            atualizarContadorSaboresKiosk();
            navegarPara('sabores');
            mostrarToast('Base selecionada: ' + kioskNomes[base]);
        }

        function toggleSaborKiosk(sabor) {
            const index = kioskPedido.sabores.indexOf(sabor);
            const btn = document.getElementById('kiosk-sabor-' + sabor);
            if (index > -1) {
                kioskPedido.sabores.splice(index, 1);
                btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50');
                btn.classList.add('bg-white');
            } else if (kioskPedido.sabores.length < 3) {
                kioskPedido.sabores.push(sabor);
                btn.classList.remove('bg-white');
                btn.classList.add('ring-4', 'ring-purple-400', 'bg-purple-50');
                mostrarToast(kioskNomes[sabor] + ' adicionado');
            } else {
                mostrarToast('Máximo de 3 sabores');
            }
            atualizarContadorSaboresKiosk();
        }

        function atualizarContadorSaboresKiosk() {
            document.getElementById('contadorSaboresKiosk').textContent = kioskPedido.sabores.length + '/3';
            const btn = document.getElementById('btnContinuarKiosk');
            if (kioskPedido.sabores.length > 0) {
                btn.disabled = false;
                btn.classList.remove('opacity-60', 'bg-gray-300');
                btn.classList.add('bg-purple-600', 'hover:bg-purple-700');
            } else {
                btn.disabled = true;
                btn.classList.add('opacity-60', 'bg-gray-300');
                btn.classList.remove('bg-purple-600', 'hover:bg-purple-700');
            }
        }

        function toggleExtraKiosk(extra) {
            const index = kioskPedido.extras.indexOf(extra);
            const btn = document.getElementById('kiosk-extra-' + extra);
            if (index > -1) {
                kioskPedido.extras.splice(index, 1);
                btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50');
                btn.classList.add('bg-white');
            } else {
                kioskPedido.extras.push(extra);
                btn.classList.remove('bg-white');
                btn.classList.add('ring-4', 'ring-purple-400', 'bg-purple-50');
                mostrarToast(kioskNomes[extra] + ' adicionado');
            }
            atualizarBadgeCarrinho();
        }

        function atualizarCarrinhoKiosk() {
            const resumo = document.getElementById('kioskResumoPedido');
            let html = '';
            if (kioskPedido.base) {
                html += '<div class="cart-item-anim flex justify-between text-gray-800 font-semibold mb-1"><span>' + kioskNomes[kioskPedido.base] + '</span><span>€' + kioskPedido.basePreco.toFixed(2) + '</span></div>';
                kioskPedido.sabores.forEach(s => {
                    html += '<div class="cart-item-anim flex justify-between text-gray-500 text-sm pl-3"><span>• ' + kioskNomes[s] + '</span><span class="text-gray-400">incluído</span></div>';
                });
                kioskPedido.extras.forEach(e => {
                    html += '<div class="cart-item-anim flex justify-between text-gray-500 text-sm pl-3"><span>+ ' + kioskNomes[e] + '</span><span>€' + kioskExtrasPrecos[e].toFixed(2) + '</span></div>';
                });
            }
            resumo.innerHTML = html || '<p class="text-gray-400 text-sm">Nenhum item no carrinho</p>';
            const extrasTotal = kioskPedido.extras.reduce((a, b) => a + kioskExtrasPrecos[b], 0);
            const total = (kioskPedido.basePreco || 0) + extrasTotal + 0.30;
            document.getElementById('kioskSubtotal').textContent = '€' + ((kioskPedido.basePreco || 0) + extrasTotal).toFixed(2);
            document.getElementById('kioskTotal').textContent = '€' + total.toFixed(2);
            document.getElementById('kioskTotalBtn').textContent = total.toFixed(2);
            atualizarBadgeCarrinho();
        }

        function atualizarBadgeCarrinho() {
            const badge = document.getElementById('badgeCarrinho');
            const count = (kioskPedido.base ? 1 : 0) + kioskPedido.extras.length;
            if (count > 0) {
                badge.textContent = count;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        function limparPedidoKiosk() {
            kioskPedido = { base: null, basePreco: 0, sabores: [], extras: [] };
            document.querySelectorAll('[id^="kiosk-sabor-"]').forEach(btn => {
                btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50');
                btn.classList.add('bg-white');
            });
            document.querySelectorAll('[id^="kiosk-extra-"]').forEach(btn => {
                btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50');
                btn.classList.add('bg-white');
            });
            kioskPagamentoSelecionado = null;
            document.querySelectorAll('.pay-method').forEach(el => el.classList.remove('selected'));
            document.getElementById('btnConfirmarPagamento').disabled = true;
            document.getElementById('btnConfirmarPagamento').classList.add('opacity-60', 'bg-gray-300');
            document.getElementById('btnConfirmarPagamento').classList.remove('bg-green-500', 'hover:bg-green-600');
            atualizarContadorSaboresKiosk();
            atualizarCarrinhoKiosk();
            navegarPara('home');
            mostrarToast('Pedido cancelado');
        }

        function selecionarPagamento(metodo) {
            kioskPagamentoSelecionado = metodo;
            document.querySelectorAll('.pay-method').forEach(el => el.classList.remove('selected'));
            document.getElementById('pay-' + metodo).classList.add('selected');
            const btn = document.getElementById('btnConfirmarPagamento');
            btn.disabled = false;
            btn.classList.remove('opacity-60', 'bg-gray-300');
            btn.classList.add('bg-green-500', 'hover:bg-green-600');
            vibrarCurto();
        }

        function confirmarPagamento() {
            if (!kioskPagamentoSelecionado) return;
            document.getElementById('pagamentoAnimacao').classList.remove('hidden');
            document.getElementById('btnConfirmarPagamento').classList.add('hidden');
            setTimeout(() => {
                document.getElementById('pagamentoAnimacao').classList.add('hidden');
                document.getElementById('btnConfirmarPagamento').classList.remove('hidden');
                document.getElementById('kioskNumeroPedido').textContent = '#' + Math.floor(40 + Math.random() * 20);
                navegarPara('confirmacao');
                if (navigator.vibrate) navigator.vibrate([50, 100, 50]);
            }, 1500);
        }

        function voltarHomeKiosk() {
            limparPedidoKiosk();
            navegarPara('home');
        }

        function pedidoRapidoDuo() {
            kioskPedido = { base: 'milkshake', basePreco: kioskPrecos.milkshake, sabores: ['menta', 'manga'], extras: ['chantilly'] };
            // atualizar visuais dos sabores
            document.querySelectorAll('[id^="kiosk-sabor-"]').forEach(btn => btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50'));
            ['menta', 'manga'].forEach(s => {
                const btn = document.getElementById('kiosk-sabor-' + s);
                if (btn) { btn.classList.remove('bg-white'); btn.classList.add('ring-4', 'ring-purple-400', 'bg-purple-50'); }
            });
            document.querySelectorAll('[id^="kiosk-extra-"]').forEach(btn => btn.classList.remove('ring-4', 'ring-purple-400', 'bg-purple-50'));
            const ebtn = document.getElementById('kiosk-extra-chantilly');
            if (ebtn) { ebtn.classList.remove('bg-white'); ebtn.classList.add('ring-4', 'ring-purple-400', 'bg-purple-50'); }
            atualizarContadorSaboresKiosk();
            navegarPara('carrinho');
            mostrarToast('Promoção Milkshake Duo adicionada!');
        }

        function atualizarRelogio() {
            const agora = new Date();
            const h = String(agora.getHours()).padStart(2, '0');
            const m = String(agora.getMinutes()).padStart(2, '0');
            document.getElementById('kioskClock').textContent = h + ':' + m;
        }
        setInterval(atualizarRelogio, 60000);
        atualizarRelogio();
    </script>
</body>
</html>
