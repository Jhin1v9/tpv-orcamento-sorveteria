                        <div class="px-4 flex-1 overflow-hidden">
                            <p class="text-white/60 text-xs mb-2">Pedidos Recentes</p>
                            <div class="space-y-2">
                                <div class="bg-white/10 rounded-lg p-2 flex justify-between items-center">
                                    <div><p class="text-white text-sm font-semibold">#041</p><p class="text-white/60 text-xs">Copo - 3 sabores</p></div>
                                    <span class="text-green-400 text-xs">Concluído</span>
                                </div>
                                <div class="bg-white/10 rounded-lg p-2 flex justify-between items-center">
                                    <div><p class="text-white text-sm font-semibold">#042</p><p class="text-white/60 text-xs">Milkshake - Menta</p></div>
                                    <span class="text-yellow-400 text-xs">Em preparo</span>
                                </div>
                                <div class="bg-white/10 rounded-lg p-2 flex justify-between items-center">
